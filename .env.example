NODE_ENV=development

HOST=0.0.0.0
PORT=3000

DB_NAME=starterdb
DB_USER=starteruser
DB_PASSWORD=starterpass
DB_HOST=db
DB_PORT=5432
DB_APP_NAME=fastify-starter
DB_TIMEZONE=UTC
PG_CONNECTION_STRING=postgres://starteruser:starterpass@db:5432/starterdb

DB_POOL_MIN=1
DB_POOL_MAX=10
DB_POOL_IDLE_TIMEOUT=10000
DB_POOL_CONNECTION_TIMEOUT=5000
DB_QUERY_TIMEOUT=30000
DB_LOCK_TIMEOUT=5000
DB_STATEMENT_TIMEOUT=30000
DB_KEEP_ALIVE_INITIAL_DELAY=30000
DB_IDLE_IN_TRANSACTION_SESSION_TIMEOUT=30000

PGBOSS_APP_NAME=starter-queue
PGBOSS_SCHEMA=queue
PGBOSS_MIGRATE=true
PGBOSS_MAX_CONN=5
PGBOSS_ARCHIVE_COMPLETED_AFTER=43200
PGBOSS_ARCHIVE_FAILED_AFTER=43200
PGBOSS_DELETE_AFTER_DAYS=7
PGBOSS_MONITOR_INTERVAL=5

S3_ENDPOINT=http://127.0.0.1:9000
S3_REGION=us-east-1
S3_BUCKET=starter
S3_ACCESS_KEY=test
S3_SECRET_PASSWORD=test

SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_POOL=false
SMTP_MAX_CONNECTIONS=5
SMTP_MAX_MESSAGES=100
SMTP_CONNECTION_TIMEOUT=120000
SMTP_SOCKET_TIMEOUT=600000
SMTP_TLS_REJECT_UNAUTHORIZED=false
MAILER_DEFAULT_FROM=Starter <no-reply@example.com>
MAILER_DEFAULT_SUBJECT=Starter Notification
MAILER_DEFAULT_REPLY_TO=
MAILER_DEFAULT_PRIORITY=normal

OPENAPI_USER=root
OPENAPI_PASS=root
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA

ADMIN_ACCESS_TOKEN_EXPIRES_SECONDS=86400
ADMIN_REFRESH_TOKEN_EXPIRES_SECONDS=604800
SERVER_KEEP_ALIVE_TIMEOUT=60000
SERVER_REQUEST_TIMEOUT=30000
SERVER_BODY_LIMIT=5242880

JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=
